{
  "name": "tenka-fubu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.core.json --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:core": "vitest run --project core --passWithNoTests",
    "test:ui": "vitest run --project ui --passWithNoTests",
    "test:app": "vitest run --project app --passWithNoTests",
    "test:golden": "vitest run tests/golden",
    "golden:update": "UPDATE_GOLDEN=1 vitest run tests/golden",
    "e2e": "npm run build && playwright test",
    "e2e:visual": "playwright test e2e/visual.spec.ts",
    "e2e:visual:update": "npm run build && UPDATE_VISUAL=1 playwright test e2e/visual.spec.ts --update-snapshots",
    "bench": "vitest bench tests/perf",
    "validate:data": "tsx tools/validate.ts && tsx tools/scan-simplified.ts && tsx tools/check-font-coverage.ts",
    "scan:simplified": "tsx tools/scan-simplified.ts",
    "font:subset": "tsx tools/subset-font.ts"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "lz-string": "^1.5.0",
    "pixi.js": "^8.6.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/subset-font": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "subset-font": "^2.5.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.9.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.3"
  }
}
